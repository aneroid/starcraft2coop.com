{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$ref": "#/definitions/MutatorInteractionList",
    "definitions": {
        "MutatorInteractionList": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/MutatorInteraction"
            }
        },
        "MutatorInteraction": {
            "type": "object",
            "properties": {
                "id1": {
                    "type": "string",
                    "description": "ID of the first mutator in the pair, Normalized",
                    "pattern": "^[a-z0-9]+$"
                },
                "id2": {
                    "type": "string",
                    "description": "ID of the second mutator in the pair, Normalized & id2 > id1",
                    "pattern": "^[a-z0-9]+$"
                },
                "interaction": {
                    "type": "string",
                    "description": "Description of how the two mutators interact"
                }
            },
            "required": [
                "id1",
                "id2",
                "interaction"
            ],
            "additionalProperties": false
        }
    }
}
